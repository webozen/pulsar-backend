# pulsar-backend (Spring Boot, host-app) — copy to .env and fill in for local dev.

# --- HTTP ---
SERVER_PORT=18080

# --- Auth ---
# Must be >=32 chars and NOT equal the public dev sentinel in production.
# Share this value with pulsar-flow-platform.
PULSAR_JWT_SECRET=changeme-at-least-32-chars-long-dev-only-replace-in-prod

# Super-admin login passcode (used at POST /api/admin/login).
PULSAR_ADMIN_PASSCODE=PULS-DEV-0000

# --- MySQL (platform + per-tenant DBs) ---
# The JDBC URL is hardcoded in host-app/src/main/resources/application.yml;
# override with SPRING_DATASOURCE_URL if you want a different host.
PULSAR_MYSQL_BASE_JDBC_URL=jdbc:mysql://localhost:3316
PULSAR_MYSQL_USER=root
PULSAR_MYSQL_PASSWORD=pulsar
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3316/pulsar_platform?useSSL=false&allowPublicKeyRetrieval=true&createDatabaseIfNotExist=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=pulsar

# --- Optional integrations ---
ANYTHINGLLM_URL=http://localhost:3001
ANYTHINGLLM_API_KEY=
PLAUD_BASE_URL=https://api.plaud.ai
PULSAR_CONTENT_UPLOAD_DIR=./uploads

# --- automation-sync bridge to pulsar-flow-platform ---
# Where the workflow platform's Next.js app is reachable from this backend.
PULSAR_AUTOMATION_BASE_URL=http://localhost:3002/automation
# Shared static secret. Must equal PULSAR_AUTOMATION_SYNC_SECRET on the
# flow-platform side. Generate with: openssl rand -hex 32
# Leave blank to disable outbound sync (lifecycle calls become no-ops; the
# audit table records skip rows so you can see which events were dropped).
PULSAR_AUTOMATION_SYNC_SECRET=
